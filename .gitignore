### --- Java 相关 (忽略编译产物) ---
target/
*.class
*.jar
*.war
.mvn/

### --- IDE 相关 (忽略本地编辑器配置) ---
.idea/
*.iml
.classpath
.project
.settings/
.DS_Store

### --- Python 相关 (最关键的部分) ---
__pycache__/
*.py[cod]
*$py.class
.venv/
.env

