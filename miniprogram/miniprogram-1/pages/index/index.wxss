/* pages/index/index.wxss */
.launch-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #ffffff;
}

.logo {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 50rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #888888;
  margin-top: 30rpx;
}

.footer-text {
  position: absolute;
  bottom: 50rpx;
  font-size: 24rpx;
  color: #cccccc;
}

/* 简单的加载小动画 */
.loader {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #800000; /* 城大红 */
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}